+/* Apply the IDL `timeout` (ms) to a socket for one blocking receive, then restore.
+ * timeout==0 leaves the socket's own SO_RCVTIMEO in force (the host sets it today), so
+ * existing callers see identical behaviour.  Returns 0 on success, -1 if a non-zero
+ * bound was requested but could NOT be installed -- the caller must then NOT run an
+ * unbounded receive (that unbounded wait is exactly the wedge N2 removes).  Unlike the
+ * broken rpc_lwip_available() below, old_timeout is a correctly sized, initialised int
+ * and optlen is initialised to its size. */
+static int rpc_lwip_apply_rcvtimeo(int32_t s, uint32_t timeout, int *old_timeout, int *restore)
+{
+    *restore = 0;
+    if (timeout == 0)
+        return 0;
+
+    socklen_t optlen = sizeof(*old_timeout);
+    /* lwIP stores recv_timeout as a signed int; clamp so a huge (or malformed) timeout
+     * cannot wrap negative and turn a bounded wait into undefined behaviour. */
+    int new_timeout = (timeout > (uint32_t)0x7fffffff) ? 0x7fffffff : (int)timeout;
+    if (lwip_getsockopt(s, SOL_SOCKET, SO_RCVTIMEO, old_timeout, &optlen) != 0 ||
+        lwip_setsockopt(s, SOL_SOCKET, SO_RCVTIMEO, &new_timeout, sizeof(new_timeout)) != 0)
+    {
+        errno = EIO;   /* couldn't arm the bound -> caller reports an error, not a wedge */
+        return -1;
+    }
+
+    *restore = 1;
+    return 0;
+}
+
+static void rpc_lwip_restore_rcvtimeo(int32_t s, int old_timeout, int restore)
+{
+    if (restore)
+        lwip_setsockopt(s, SOL_SOCKET, SO_RCVTIMEO, &old_timeout, sizeof(old_timeout));
+}
