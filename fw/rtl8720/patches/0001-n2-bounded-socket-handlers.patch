+     * SO_ERROR tells success from failure once selected.  Restore the flags exactly.
+     * If the non-blocking mode cannot be installed, fail closed (-1) rather than run an
+     * unbounded blocking connect. */
+    int flags = lwip_fcntl(s, F_GETFL, 0);
