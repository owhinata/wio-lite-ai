+
+/* N2 (issue #20): bound the handlers that would otherwise block the single FreeRTOS
+ * eRPC-server task forever.  The IDL gives recv/read/recvfrom a `timeout`; connect and
+ * accept have none, so they get an internal cap.  These are the ceilings for the
+ * capped paths -- generous enough not to trip a healthy peer, short enough that a dead
+ * one cannot wedge the module until `wifi reset`. */
+#define RPC_LWIP_CONNECT_TIMEOUT_MS 20000
+#define RPC_LWIP_ACCEPT_TIMEOUT_MS  10000
+
 int32_t rpc_lwip_accept(int32_t s, const binary_t *addr, uint32_t *addrlen)
 {
     log_d("called");
     struct sockaddr *_addr = (struct sockaddr *)addr->data;
-    return lwip_accept(s, _addr, &addr->dataLength);
+
+    /* Cap the wait: save the socket's flags, go non-blocking, wait for an incoming
+     * connection with lwip_select up to the cap, accept it, then restore the flags
+     * exactly (a future host may itself rely on O_NONBLOCK).  If the non-blocking mode
+     * cannot be installed, fail closed (-1) rather than run an unbounded blocking
+     * accept -- an unbounded wait is exactly the wedge N2 removes. */
+    int flags = lwip_fcntl(s, F_GETFL, 0);
+    if (flags < 0)
+    {
+        errno = EIO;
+        return -1;
+    }
+    if (lwip_fcntl(s, F_SETFL, flags | O_NONBLOCK) < 0)
+    {
+        errno = EIO;
+        return -1;
+    }
+
+    fd_set rset;
+    struct timeval tv;
+    FD_ZERO(&rset);
+    FD_SET(s, &rset);
+    tv.tv_sec = RPC_LWIP_ACCEPT_TIMEOUT_MS / 1000;
+    tv.tv_usec = 0;
+
+    int32_t ret;
+    if (lwip_select(s + 1, &rset, NULL, NULL, &tv) > 0 && FD_ISSET(s, &rset))
+    {
+        ret = lwip_accept(s, _addr, &addr->dataLength);
+    }
+    else
+    {
+        errno = ETIMEDOUT;   /* timeout or select error -> report, do not block */
+        ret = -1;
+    }
+
+    lwip_fcntl(s, F_SETFL, flags);   /* restore the original blocking mode exactly */
+    return ret;
 }
 
