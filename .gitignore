# Build output
/build/

# RTL8720DN device firmware build (issue #20).  fw/rtl8720/build.sh exports the pinned
# upstream commit here, compiles it and drops the images -- all reproducible from the
# pins in build.sh, so none of it belongs in git.
/fw/rtl8720/out/

# Downloaded ARM GNU toolchain (fetched by cmake/arm-none-eabi-toolchain.cmake)
/tools/

# Python
__pycache__/

# Reference material (schematics, datasheets, vendor SDK zips, flash backups) --
# large binaries, not source. Kept locally only.
/_ref/

# Editor swap / backup files (Vim .*.swp/.swo, emacs/gedit ~ backups)
*.sw[a-p]
*~

# RTL8720DN flash dumps that land here from a YMODEM receive (`wifi flashbackup` /
# `wifi imgsend` + `rb`, which writes to the terminal's working directory -- issue
# #19).  NEVER commit these: a full-chip image contains the factory WiFi settings
# sector at 0x105000, and the PSK in it is in the clear.  Keep them in _ref/ambd/.
/rtl8720_*.bin
