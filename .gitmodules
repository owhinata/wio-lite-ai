[submodule "lib/cmsis_device_h7"]
	path = lib/cmsis_device_h7
	url = https://github.com/STMicroelectronics/cmsis_device_h7
[submodule "lib/stm32h7xx_hal_driver"]
	path = lib/stm32h7xx_hal_driver
	url = https://github.com/STMicroelectronics/stm32h7xx_hal_driver
[submodule "lib/cmsis_core"]
	path = lib/cmsis_core
	url = https://github.com/STMicroelectronics/cmsis-core
	branch = cm7
[submodule "lib/tinyusb"]
	path = lib/tinyusb
	url = https://github.com/hathach/tinyusb.git
[submodule "lib/threadx"]
	path = lib/threadx
	url = https://github.com/eclipse-threadx/threadx.git
